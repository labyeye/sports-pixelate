JWT_SECRET="change_me_to_a_long_random_string"
MONGO_URI="mongodb://localhost:27017/nestsports"
PORT=5002
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Razorpay — get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# HDFC SmartGateway — only needed when HDFC merchant account is ready
HDFC_MERCHANT_ID=
HDFC_ACCESS_KEY=
HDFC_ENV=uat

# WhatsApp Business API (Meta) — optional
META_WA_TOKEN=
META_WA_PHONE_ID=

# Web Push Notifications (VAPID) — generate your own: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@nestsports.example

FACE_SERVICE_URL=http://127.0.0.1:8091
FACE_SERVICE_API_KEY=
